  "rules": [
    {
      "id": "RULE-1",
      "section": "3.1",
      "title": "Dues Requirement",
      "description": "Residents must be current on HOA dues to submit maintenance requests."
    },
    {
      "id": "RULE-2",
      "section": "3.2",
      "title": "Violation Resolution",
      "description": "All outstanding violations must be resolved before submitting maintenance requests."
    },
    {
      "id": "RULE-3",
      "section": "3.3",
      "title": "Board Approval",
      "description": "Maintenance requests exceeding $500 require board approval via the request_board_approval tool."
    },
    {
      "id": "RULE-4",
      "section": "3.4",
      "title": "Budget Constraints",
      "description": "The maintenance committee must verify sufficient budget remains in the relevant category before board approval."
    },
    {
      "id": "RULE-5",
      "section": "4.1",
      "title": "Noise Ordinance",
      "description": "Quiet hours are 10pm-7am. Violations result in a fine of $50-$100."
    },
    {
      "id": "RULE-6",
      "section": "4.2",
      "title": "Parking Rules",
      "description": "Each unit is assigned one parking spot. Unauthorized vehicles will be fined."
    },
    {
      "id": "RULE-7",
      "section": "4.3",
      "title": "Pet Policy",
      "description": "All pets must be leashed in common areas. Maximum 2 pets per unit."
    },
    {
      "id": "RULE-8",
      "section": "4.4",
      "title": "Balcony Modifications",
      "description": "Any modifications to balconies require prior written approval from the board."
    }
  ]
